# dex global profile configuration
# Copy this file to ~/.dex.conf and edit it to suit your setup.
#
# This file defines named profiles. Each profile specifies the Docker image to
# use and a base set of environment variables to pass into the container.
# Profiles can also define command aliases (see [alias:<name>] sections below).
#
# Per-project configuration (which profile to use, custom aliases, optional
# image/Dockerfile overrides) lives in ~/.dex.d/<name>.conf files.

# ──────────────────────────────────────────────────────────────────────────────
# Profile: default
# Used when no project config specifies a different profile.
# ──────────────────────────────────────────────────────────────────────────────
[default]
image = ubuntu:22.04

# Optional: build the container image from a local Dockerfile instead of
# pulling a pre-built image.  Absolute paths are used as-is; relative paths
# are resolved relative to the directory that contains this config file.
# The built image is tagged as "dex-<repo-slug>-<profile-slug>:local".
# It is built automatically on first use, or when --rebuild is passed.
#dockerfile = Dockerfile.dev

# Optional: comma-separated list of host:container port mappings to publish
# when the container is created (same format as 'docker run -p').
# Port bindings are fixed at container creation time; to apply changes after
# modifying this key, remove the container first: docker rm -f <name>
#ports = 8080:8080,5432:5432

# Optional: comma-separated list of volume mounts to create when the container
# is created (same format as 'docker run -v').
#volumes = /host/path:/container/path,/another/host/path:/another/container/path

# Optional: command to execute on container creation before any alias commands run. This is useful for setup steps that need to be done once per container, such as installing dependencies or setting up a database.
#setup = sudo chown -R $(id -u):$(id -g) /workspace

# Comma-separated list of environment variables to pass into the container.
#   KEY            — pass the host value of KEY (skipped if KEY is unset on host)
#   KEY=VALUE      — set KEY to a fixed VALUE regardless of the host environment
#   KEY=$(cmd)     — evaluate cmd on the host and use its output as the value
#   KEY=`cmd`      — same, backtick style
env = CC,CXX,MAKEFLAGS

# ──────────────────────────────────────────────────────────────────────────────
# Aliases for the [default] profile
# Each [alias:<name>] section defines a shorthand command.
#   dex <name>  →  runs 'cmd' in 'workdir' with 'env' applied
# ──────────────────────────────────────────────────────────────────────────────

[alias:configure]
# Run CMake configuration step
cmd     = cmake -S /workspace -B /workspace/build
workdir = /workspace

[alias:build]
# Build the project (parallelism via JOBS env var or host MAKEFLAGS)
cmd     = cmake --build /workspace/build
workdir = /workspace/build
# Fixed env for this alias (merged with the profile's base env)
env     = JOBS=4

[alias:test]
# Run tests via CTest
cmd     = ctest --test-dir /workspace/build --output-on-failure
workdir = /workspace/build

[alias:shell]
# Open an interactive shell at the workspace root.
# interactive = true makes this alias always run with a TTY (docker exec -it),
# even when invoked as a step inside a pipeline.
cmd         = bash
workdir     = /workspace
interactive = true

# ──────────────────────────────────────────────────────────────────────────────
# Pipeline aliases
# A pipeline alias runs a sequence of other aliases in order, each with its own
# header, output display, and footer. The pipeline stops on the first failure.
#   pipeline = <alias1>,<alias2>,...
# The step aliases must be defined in this config (or in the project config).
# Step aliases can still be invoked individually as well.
# ──────────────────────────────────────────────────────────────────────────────

[alias:ci]
# Run the full configure → build → test pipeline in one invocation.
pipeline = configure,build,test

# ──────────────────────────────────────────────────────────────────────────────
# Hidden aliases
# Set hidden = true to make an alias internal-only: it will not appear in
# --list output and cannot be invoked directly (dex <name> runs the literal
# command in the container instead).  Hidden aliases can still be used as
# steps inside a pipeline.
# ──────────────────────────────────────────────────────────────────────────────

# Example: 'prepare' is only called by the 'ci' pipeline, never directly.
#[alias:prepare]
#hidden  = true
#cmd     = cmake -S /workspace -B /workspace/build -DCMAKE_BUILD_TYPE=Release
#workdir = /workspace

# ──────────────────────────────────────────────────────────────────────────────
# Profile: clang
# Example of an alternate profile using a Clang-based image.
# ──────────────────────────────────────────────────────────────────────────────
[clang]
image = silkeh/clang:18
env   = CC=clang,CXX=clang++,MAKEFLAGS
# Expose a debug port for this profile only
#ports = 5678:5678

[alias:configure]
cmd     = cmake -S /workspace -B /workspace/build -DCMAKE_BUILD_TYPE=Release
workdir = /workspace

[alias:build]
cmd     = cmake --build /workspace/build -- -j$(nproc)
workdir = /workspace/build
