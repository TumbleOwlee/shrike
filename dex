#!/usr/bin/env bash
# dex: Run commands in a persistent Docker container.
#
# The git repository root is auto-detected and mounted as /workspace. The
# current working directory is translated to the equivalent container path.
#
# Config hierarchy (highest priority first):
#   1. Local project config : ~/.dex.d/*.conf  (matched by 'pattern')
#   2. Repository config    : <git-root>/.dex.conf
#   3. Global config        : ~/.dex.conf
#
# Usage: dex [OPTIONS] [<alias>|<command> [args...]]

set -euo pipefail

readonly SCRIPT_NAME="$(basename "$0")"

# Resolve global config: prefer $HOME, fall back to $HOME/.local/share
if [[ -f "${HOME}/.dex.conf" ]]; then
    GLOBAL_CONFIG="${HOME}/.dex.conf"
else
    GLOBAL_CONFIG="${HOME}/.local/share/.dex.conf"
fi
readonly GLOBAL_CONFIG

# Resolve project config dir: prefer $HOME, fall back to $HOME/.local/share
if [[ -d "${HOME}/.dex.d" ]]; then
    PROJECT_CONFIG_DIR="${HOME}/.dex.d"
else
    PROJECT_CONFIG_DIR="${HOME}/.local/share/.dex.d"
fi
readonly PROJECT_CONFIG_DIR
readonly CONTAINER_MOUNT="/workspace"
# Separator used inside associative array keys (must not appear in file paths or section names)
readonly _SEP="::::"

# ──────────────────────────────────────────────────────────────────────────────
# Utilities
# ──────────────────────────────────────────────────────────────────────────────
die() {
    local B="" RD="" R=""
    if [[ -t 2 ]]; then
        B=$'\033[1m'
        RD=$'\033[1;31m'
        R=$'\033[0m'
    fi
    printf >&2 "\n ${RD}${B}✗  error:${R}  %b\n\n" "$*"
    exit 1
}
warn() {
    local B="" YL="" R=""
    if [[ -t 2 ]]; then
        B=$'\033[1m'
        YL=$'\033[1;33m'
        R=$'\033[0m'
    fi
    printf >&2 " ${YL}${B}⚠  warning:${R}  %b\n" "$*"
}
info() {
    local CY="" R=""
    if [[ -t 2 ]]; then
        CY=$'\033[36m'
        R=$'\033[0m'
    fi
    printf >&2 " ${CY}·${R}  %b\n" "$*"
}

# Inline colour variables for highlighted content inside messages.
# Set once at startup; empty when stderr is not a TTY so messages stay plain
# when piped or redirected.
_CB="" _CCY="" _CYL="" _CGR="" _CDIM="" _CR=""
if [[ -t 2 ]]; then
    _CB=$'\033[1m'
    _CCY=$'\033[1;36m'
    _CYL=$'\033[1;33m'
    _CGR=$'\033[0;32m'
    _CDIM=$'\033[2m'
    _CR=$'\033[0m'
fi

# ──────────────────────────────────────────────────────────────────────────────
# INI parser
# Values are stored in the global associative array _CFG with keys of the form:
#   "<file>::::<section>::::<key>"
# Section names are preserved as-is (e.g. "alias:build").
# ──────────────────────────────────────────────────────────────────────────────
declare -A _CFG=()

ini_parse() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    local section="" line key val current_profile=""
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip full-line comments and empty lines
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        # Strip trailing whitespace
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue
        if [[ "$line" =~ ^\[(.+)\]$ ]]; then
            local raw="${BASH_REMATCH[1]}"
            if [[ "$raw" == "alias:"* && -n "$current_profile" ]]; then
                # Qualify alias sections with their owning profile so that the same
                # alias name can be defined differently under different profiles.
                # Storage key: alias:<profile>:<name> (e.g. alias:clang:build)
                # Project config files have no profile sections, so current_profile
                # stays empty and aliases are stored as-is (alias:<name>).
                section="alias:${current_profile}:${raw#alias:}"
            else
                section="$raw"
                # Track which profile section we are currently inside.
                if [[ "$raw" != "alias:"* && "$raw" != "project" ]]; then
                    current_profile="$raw"
                fi
            fi
        elif [[ "$line" =~ ^([^=]+[^[:space:]=])[[:space:]]*=[[:space:]]*(.*) ]]; then
            key="${BASH_REMATCH[1]}"
            val="${BASH_REMATCH[2]}"
            val="${val%"${val##*[![:space:]]}"}" # rtrim value
            [[ -n "$section" ]] && _CFG["${file}${_SEP}${section}${_SEP}${key}"]="$val"
        fi
    done <"$file"
}

# ini_get <file> <section> <key> [default]
ini_get() {
    printf '%s' "${_CFG["${1}${_SEP}${2}${_SEP}${3}"]-${4-}}"
}

# Returns 0 if section exists in the parsed file
ini_has_section() {
    local file="$1" section="$2" k
    for k in "${!_CFG[@]}"; do
        [[ "$k" == "${file}${_SEP}${section}${_SEP}"* ]] && return 0
    done
    return 1
}

# Print unique section names for a parsed file (one per line)
ini_sections() {
    local file="$1" k section
    local -A _seen=()
    for k in "${!_CFG[@]}"; do
        [[ "$k" != "${file}${_SEP}"* ]] && continue
        # Strip file prefix, then strip key suffix (use %% to take longest match)
        section="${k#"${file}${_SEP}"}"
        section="${section%%"${_SEP}"*}"
        if [[ -z "${_seen[$section]+x}" ]]; then
            _seen[$section]=1
            printf '%s\n' "$section"
        fi
    done
}

# ──────────────────────────────────────────────────────────────────────────────
# Config state (populated by load_profile / apply_project_config)
# ──────────────────────────────────────────────────────────────────────────────
PROFILE_IMAGE=""
PROFILE_ENV=""
PROFILE_DOCKERFILE=""
PROFILE_PORTS=""
PROJECT_FILE=""
PROJECT_IMAGE=""
PROJECT_DOCKERFILE=""
REPO_CONFIG=""

declare -A ALIAS_CMD=()
declare -A ALIAS_DESC=()
declare -A ALIAS_WORKDIR=()
declare -A ALIAS_ENV=()
declare -A ALIAS_PIPELINE=()
declare -A ALIAS_INTERACTIVE=()
declare -A ALIAS_HIDDEN=()

# Load a profile section and its alias sub-sections from the lowest-priority
# source that defines the profile (global config first, then repo config, then
# local project config).  Higher-priority layers are applied afterwards by
# apply_project_config via _apply_config_layer.
load_profile() {
    local profile="$1"
    local _src=""
    if ini_has_section "$GLOBAL_CONFIG" "$profile"; then
        _src="$GLOBAL_CONFIG"
    elif [[ -n "$REPO_CONFIG" ]] && ini_has_section "$REPO_CONFIG" "$profile"; then
        _src="$REPO_CONFIG"
    elif [[ -n "$PROJECT_FILE" ]] && ini_has_section "$PROJECT_FILE" "$profile"; then
        _src="$PROJECT_FILE"
    else
        local _hint=""
        [[ -n "$REPO_CONFIG" ]] && _hint+=" or ${_CGR}${REPO_CONFIG}${_CR}"
        [[ -n "$PROJECT_FILE" ]] && _hint+=" or ${_CGR}${PROJECT_FILE}${_CR}"
        die "Profile '${_CCY}${profile}${_CR}' not found in ${_CGR}${GLOBAL_CONFIG}${_CR}${_hint}."
    fi
    PROFILE_IMAGE="$(ini_get "$_src" "$profile" "image")"
    PROFILE_ENV="$(ini_get "$_src" "$profile" "env")"
    PROFILE_DOCKERFILE="$(ini_get "$_src" "$profile" "dockerfile")"
    if [[ -n "$PROFILE_DOCKERFILE" && "$PROFILE_DOCKERFILE" != /* ]]; then
        PROFILE_DOCKERFILE="$(dirname "$_src")/${PROFILE_DOCKERFILE}"
    fi
    PROFILE_PORTS="$(ini_get "$_src" "$profile" "ports")"
    local section _prefix="alias:${profile}:"
    while IFS= read -r section; do
        [[ "$section" == "${_prefix}"* ]] || continue
        local aname="${section#"$_prefix"}"
        ALIAS_CMD["$aname"]="$(ini_get "$_src" "$section" "cmd")"
        ALIAS_DESC["$aname"]="$(ini_get "$_src" "$section" "desc")"
        ALIAS_WORKDIR["$aname"]="$(ini_get "$_src" "$section" "workdir" "$CONTAINER_MOUNT")"
        ALIAS_ENV["$aname"]="$(ini_get "$_src" "$section" "env")"
        ALIAS_PIPELINE["$aname"]="$(ini_get "$_src" "$section" "pipeline")"
        ALIAS_INTERACTIVE["$aname"]="$(ini_get "$_src" "$section" "interactive")"
        ALIAS_HIDDEN["$aname"]="$(ini_get "$_src" "$section" "hidden")"
    done < <(ini_sections "$_src")
}

# Scan ~/.dex.d/*.conf for a file whose 'pattern' matches the git root
find_project_config() {
    local git_root="$1"
    [[ -d "$PROJECT_CONFIG_DIR" ]] || return 0
    local conf pattern
    for conf in "$PROJECT_CONFIG_DIR"/*.conf; do
        [[ -f "$conf" ]] || continue
        ini_parse "$conf"
        pattern="$(ini_get "$conf" "project" "pattern")"
        [[ -z "$pattern" ]] && continue
        if [[ "$git_root" =~ $pattern ]]; then
            PROJECT_FILE="$conf"
            return 0
        fi
    done
}

# Look for an in-repository config at <git-root>/.dex.conf.
find_repo_config() {
    local git_root="$1"
    local _candidate="${git_root}/.dex.conf"
    if [[ -f "$_candidate" ]]; then
        REPO_CONFIG="$_candidate"
        ini_parse "$REPO_CONFIG"
    fi
}

# Apply one config layer's overrides on top of the already-loaded profile.
# Handles [project] image/dockerfile, profile-level field overrides, and both
# profile-scoped and unscoped alias definitions.
# Called in ascending priority order: repo config first, then local project config.
_apply_config_layer() {
    local src="$1" profile="$2"
    if [[ -z "$src" || ! -f "$src" ]]; then
        return 0
    fi

    # [project] section: image and dockerfile overrides.
    local _img _dockerfile
    _img="$(ini_get "$src" "project" "image")"
    _dockerfile="$(ini_get "$src" "project" "dockerfile")"
    [[ -n "$_img" ]] && PROJECT_IMAGE="$_img"
    if [[ -n "$_dockerfile" ]]; then
        [[ "$_dockerfile" != /* ]] && _dockerfile="$(dirname "$src")/${_dockerfile}"
        PROJECT_DOCKERFILE="$_dockerfile"
    fi

    # Profile section: override individual profile fields if present.
    if ini_has_section "$src" "$profile"; then
        local _pimg _penv _pdockerfile _pports
        _pimg="$(ini_get "$src" "$profile" "image")"
        _penv="$(ini_get "$src" "$profile" "env")"
        _pdockerfile="$(ini_get "$src" "$profile" "dockerfile")"
        _pports="$(ini_get "$src" "$profile" "ports")"
        [[ -n "$_pimg" ]] && PROFILE_IMAGE="$_pimg"
        [[ -n "$_penv" ]] && PROFILE_ENV="$_penv"
        if [[ -n "$_pdockerfile" ]]; then
            [[ "$_pdockerfile" != /* ]] && _pdockerfile="$(dirname "$src")/${_pdockerfile}"
            PROFILE_DOCKERFILE="$_pdockerfile"
        fi
        [[ -n "$_pports" ]] && PROFILE_PORTS="$_pports"
    fi

    local section aname cmd desc workdir aenv apipeline ainteractive ahidden

    # Pass 1: profile-scoped aliases (alias:<profile>:<name>).
    local _prefix="alias:${profile}:"
    while IFS= read -r section; do
        [[ "$section" == "${_prefix}"* ]] || continue
        aname="${section#"$_prefix"}"
        cmd="$(ini_get "$src" "$section" "cmd")"
        desc="$(ini_get "$src" "$section" "desc")"
        workdir="$(ini_get "$src" "$section" "workdir" "")"
        aenv="$(ini_get "$src" "$section" "env")"
        apipeline="$(ini_get "$src" "$section" "pipeline")"
        ainteractive="$(ini_get "$src" "$section" "interactive")"
        ahidden="$(ini_get "$src" "$section" "hidden")"
        [[ -n "$cmd" ]] && ALIAS_CMD["$aname"]="$cmd"
        [[ -n "$desc" ]] && ALIAS_DESC["$aname"]="$desc"
        [[ -n "$workdir" ]] && ALIAS_WORKDIR["$aname"]="$workdir"
        ALIAS_ENV["$aname"]="$aenv"
        [[ -n "$apipeline" ]] && ALIAS_PIPELINE["$aname"]="$apipeline"
        [[ -n "$ainteractive" ]] && ALIAS_INTERACTIVE["$aname"]="$ainteractive"
        [[ -n "$ahidden" ]] && ALIAS_HIDDEN["$aname"]="$ahidden"
    done < <(ini_sections "$src")

    # Pass 2: unscoped aliases (alias:<name>) — higher precedence within this layer.
    while IFS= read -r section; do
        [[ "$section" == "alias:"* ]] || continue
        aname="${section#alias:}"
        [[ "$aname" == *:* ]] && continue # skip profile-scoped (alias:<profile>:<name>)
        cmd="$(ini_get "$src" "$section" "cmd")"
        desc="$(ini_get "$src" "$section" "desc")"
        workdir="$(ini_get "$src" "$section" "workdir" "")"
        aenv="$(ini_get "$src" "$section" "env")"
        apipeline="$(ini_get "$src" "$section" "pipeline")"
        ainteractive="$(ini_get "$src" "$section" "interactive")"
        ahidden="$(ini_get "$src" "$section" "hidden")"
        [[ -n "$cmd" ]] && ALIAS_CMD["$aname"]="$cmd"
        [[ -n "$desc" ]] && ALIAS_DESC["$aname"]="$desc"
        [[ -n "$workdir" ]] && ALIAS_WORKDIR["$aname"]="$workdir"
        ALIAS_ENV["$aname"]="$aenv"
        [[ -n "$apipeline" ]] && ALIAS_PIPELINE["$aname"]="$apipeline"
        [[ -n "$ainteractive" ]] && ALIAS_INTERACTIVE["$aname"]="$ainteractive"
        [[ -n "$ahidden" ]] && ALIAS_HIDDEN["$aname"]="$ahidden"
    done < <(ini_sections "$src")
}

# Apply config layers in ascending priority: repo config first, then local
# project config.  Each layer can override what was set by lower-priority layers.
#
# Overall alias precedence (highest wins):
#   global base  <  repo layer  <  project-local layer
#   within each layer: unscoped alias > profile-scoped alias
apply_project_config() {
    local profile="$1"
    _apply_config_layer "$REPO_CONFIG" "$profile"
    _apply_config_layer "$PROJECT_FILE" "$profile"
}

# ──────────────────────────────────────────────────────────────────────────────
# Environment flag builder
# Accepts a comma-separated list of entries:
#   KEY              — pass the host value of KEY (skipped if KEY is unset)
#   KEY=VALUE        — set KEY to a fixed VALUE
#   KEY=$(cmd)       — evaluate cmd on the host and use its output as the value
#   KEY=`cmd`        — same, backtick style
# Writes null-delimited "-e" / "KEY=VALUE" pairs to stdout for use with readarray
# ──────────────────────────────────────────────────────────────────────────────
build_env_flags() {
    local env_spec="$1"
    [[ -z "$env_spec" ]] && return 0
    local spec _key _rawval _val
    local IFS=','
    for spec in $env_spec; do
        spec="${spec#"${spec%%[![:space:]]*}"}" # ltrim
        spec="${spec%"${spec##*[![:space:]]}"}" # rtrim
        [[ -z "$spec" ]] && continue
        if [[ "$spec" == *=* ]]; then
            _key="${spec%%=*}"
            _rawval="${spec#*=}"
            # If the value contains a command substitution, evaluate it on the
            # host before passing to the container.  Plain KEY=VALUE is unchanged.
            # NOTE: do NOT wrap _rawval in extra double-quotes when calling eval —
            # doing so turns single-quoted strings inside $(...) into literals,
            # breaking patterns like grep -oP 'regex' and causing bash to corrupt
            # its variable-context stack (pop_var_context error).
            if [[ "$_rawval" == *'$('* || "$_rawval" == *'`'* ]]; then
                eval "_val=${_rawval}"
                printf '%s\0' "-e" "${_key}=${_val}"
            else
                printf '%s\0' "-e" "$spec"
            fi
        else
            # Only pass through if the variable is set on the host
            [[ -n "${!spec+x}" ]] && printf '%s\0' "-e" "${spec}=${!spec}"
        fi
    done
}

# Populate ENV_FLAGS[] and ENV_DISPLAY from COMBINED_ENV.
# Called after COMBINED_ENV is assembled; sets both globals used by run_exec_step
# and print_summary.
_apply_combined_env() {
    ENV_FLAGS=()
    while IFS= read -r -d '' flag; do
        ENV_FLAGS+=("$flag")
    done < <(build_env_flags "$COMBINED_ENV")
    ENV_DISPLAY=""
    for ((_i = 1; _i < ${#ENV_FLAGS[@]}; _i += 2)); do
        ENV_DISPLAY+="${ENV_FLAGS[$_i]}, "
    done
    ENV_DISPLAY="${ENV_DISPLAY%, }"
}

# ──────────────────────────────────────────────────────────────────────────────
# Derive a deterministic, DNS-safe container name from the git root path
# ──────────────────────────────────────────────────────────────────────────────
container_name_from_path() {
    local slug
    slug="$(printf '%s' "$1" |
        tr '[:upper:]' '[:lower:]' |
        tr -cs 'a-z0-9' '-' |
        sed 's/^-\+//;s/-\+$//')"
    printf 'dex-%s' "$slug"
}

# ──────────────────────────────────────────────────────────────────────────────
# Image & container lifecycle
# ──────────────────────────────────────────────────────────────────────────────
ensure_image() {
    local image="$1" dockerfile="$2" force_rebuild="$3"
    if [[ -n "$dockerfile" ]]; then
        [[ -f "$dockerfile" ]] || die "Dockerfile not found: ${_CGR}${dockerfile}${_CR}"
        if [[ "$force_rebuild" == "1" ]] || ! docker image inspect "$image" &>/dev/null; then
            info "Building image '${_CYL}${image}${_CR}' from ${_CGR}${dockerfile}${_CR} ..."
            docker build -t "$image" -f "$dockerfile" "$(dirname "$dockerfile")"
        fi
    elif [[ "$force_rebuild" == "1" ]]; then
        warn "--rebuild has no effect: no dockerfile is configured for profile '${_CCY}${PROFILE_NAME}${_CR}'"
    fi
}

ensure_container() {
    local container="$1" image="$2" git_root="$3" ports_spec="${4:-}" force_restart="${5:-0}" force_stop="${6:-0}"

    # Build -p flags from the comma-separated ports spec (e.g. "8080:80,443:443").
    local -a _port_flags=()
    if [[ -n "$ports_spec" ]]; then
        local IFS=',' _p
        for _p in $ports_spec; do
            _p="${_p#"${_p%%[![:space:]]*}"}" # ltrim
            _p="${_p%"${_p##*[![:space:]]}"}" # rtrim
            [[ -n "$_p" ]] && _port_flags+=("-p" "$_p")
        done
    fi

    if [[ "$force_stop" == "1" ]]; then
        if docker container inspect "$container" &>/dev/null; then
            info "Removing container '${_CDIM}${container}${_CR}' ..."
            docker rm -f "$container" >/dev/null
        else
            info "Container '${_CYL}$container${_CR}' already stopped."
        fi
        exit 0
    fi

    # --restart: remove the existing container so it is recreated fresh (e.g.
    # to apply updated port mappings or pick up a new image).
    if [[ "$force_restart" == "1" ]] && docker container inspect "$container" &>/dev/null; then
        info "Removing container '${_CDIM}${container}${_CR}' for restart ..."
        docker rm -f "$container" >/dev/null
    fi

    if docker container inspect "$container" &>/dev/null; then
        local status
        status="$(docker container inspect --format '{{.State.Status}}' "$container")"
        if [[ "$status" != "running" ]]; then
            info "Starting container '${_CDIM}${container}${_CR}' ..."
            docker start "$container" >/dev/null
        fi
    else
        info "Creating container '${_CDIM}${container}${_CR}' from image '${_CYL}${image}${_CR}' ..."
        docker run -d \
            --name "$container" \
            -v "${git_root}:${CONTAINER_MOUNT}" \
            "${_port_flags[@]}" \
            "$image" \
            sleep infinity >/dev/null
    fi
}

_TERM_COLS=$(tput cols 2>/dev/null  || echo 120)
if [[ $_TERM_COLS -gt 120 ]]; then
    _TERM_COLS=120
fi

# ──────────────────────────────────────────────────────────────────────────────
# Rolling output display (non-interactive mode)
# Reads lines from stdin and keeps a live rolling window of the last N lines.
# When stdout is a terminal, ANSI cursor movement is used to update in place.
# When stdout is not a terminal (piped/redirected), lines are printed verbatim.
#
# Lines wider than the terminal are pre-split into physical-row–sized chunks
# before being added to the buffer.  Each buffer slot therefore represents
# exactly one physical row, so the cursor-up distance is always simply $max —
# no need to recompute physical row counts on every iteration.
# ──────────────────────────────────────────────────────────────────────────────
_rolling_display() {
    local max="$1" logfile="${2:-}"
    local -a buf=()
    local is_tty=0
    local cursor_up=0 # physical rows the cursor is currently above resting pos
    local content_width=0
    # Prefix for output lines — colored pipe when stdout is a TTY
    local PFX="   │ "
    if [[ -t 1 ]]; then
        is_tty=1
        PFX="   \033[36m│\033[0m "
        local _tw=$_TERM_COLS
        [[ "$_tw" =~ ^[0-9]+$ ]] || _tw=80
        # Subtract the 5 display columns used by the "   │ " prefix.
        ((_tw > 5)) && content_width=$((_tw - 5)) || content_width=0
    fi

    # Regex stored in a variable to avoid bash misparse of embedded '[' inside [[ ]].
    local _ansi_re=$'\033\[[0-9;]*[A-Za-z]'

    while IFS= read -r line; do
        # Write raw line to logfile before any display processing.
        if [[ -n "$logfile" ]]; then
            printf '%s\n' "$line" >>"$logfile"  2>/dev/null  || true
        fi

        # If line ends with \r, remove it to prevent empty lines
        if [[ "$line" =~ \r[[:space:]]*$ ]]; then
            line="${line%%$'\r'*}"
        fi
        # Strip everything up to and including the last \r so that progress-bar
        # style output (which uses \r to overwrite) doesn't clobber the │ border.
        line="${line##*$'\r'}"

        if [[ -z "$line" ]]; then
            continue
        fi

        # Strip ANSI CSI escape sequences for display.  Escape bytes inflate the
        # byte count without occupying terminal columns; preserving them correctly
        # across arbitrary chunk boundaries is complex and unnecessary here since
        # the logfile retains the full raw output.
        local _plain="$line"
        while [[ "$_plain" =~ $_ansi_re ]]; do
            _plain="${_plain//"${BASH_REMATCH[0]}"/}"
        done

        # Split into physical-row–sized chunks.  Each chunk is at most
        # content_width visible characters wide (fits one terminal row after the
        # prefix).  When content_width is 0 (unknown terminal), no splitting.
        local -a _chunks=()
        if ((content_width > 0 && ${#_plain} > content_width)); then
            local _pos=0
            while ((_pos < ${#_plain})); do
                _chunks+=("${_plain:$_pos:$content_width}")
                ((_pos += content_width))
            done
        else
            _chunks=("$_plain")
        fi

        # Insert each chunk into the buffer using the rolling-window logic.
        # Because each slot = 1 physical row, cursor-up is always $max.
        local _chunk
        for _chunk in "${_chunks[@]}"; do
            if ((${#buf[@]} >= max)); then
                buf=("${buf[@]:1}")
                buf+=("$_chunk")
                if [[ $is_tty -eq 1 ]]; then
                    # Record displacement BEFORE moving the cursor so that if
                    # SIGINT fires mid-reprint the cleanup below can recover.
                    cursor_up=$max
                    printf '\033[%dA\033[J' "$max" 2>/dev/null  || true
                    printf "${PFX}%s\n" "${buf[@]}" 2>/dev/null  || true
                    cursor_up=0 # reprint done; cursor back at resting pos
                else
                    printf "${PFX}%s\n" "$_chunk" 2>/dev/null  || true
                fi
            else
                buf+=("$_chunk")
                printf "${PFX}%s\n" "$_chunk" 2>/dev/null  || true
            fi
        done
    done

    # If SIGINT interrupted a cursor-up+reprint cycle the cursor is still
    # displaced above its resting position.  Move it back down so the footer
    # prints below the output area rather than on top of the header.
    if [[ $is_tty -eq 1 && $cursor_up -gt 0 ]]; then
        printf '\033[%dB' "$cursor_up" 2>/dev/null  || true
    fi
    return 0
}

# ──────────────────────────────────────────────────────────────────────────────
# Timing helpers
# ──────────────────────────────────────────────────────────────────────────────

# Returns current time in milliseconds (GNU date); falls back to whole seconds.
_now_ms() {
    date +%s%3N 2>/dev/null || (($(date +%s) * 1000))
}

# Formats a millisecond duration into a human-readable string.
_fmt_duration() {
    local ms="$1"
    if ((ms < 1000)); then
        printf '%dms' "$ms"
    elif ((ms < 60000)); then
        printf '%d.%ds' "$((ms / 1000))" "$(((ms % 1000) / 100))"
    else
        printf '%dm %ds' "$((ms / 60000))" "$(((ms % 60000) / 1000))"
    fi
}

_line_extension() {
    local _ext="────────────────────"
    local _offset=90
    local _line=""
    while [[ $_offset -lt $_TERM_COLS ]]; do
        _line+="$_ext"
        ((_offset += 10))
    done
    printf '%s\n' "$_line"
}

# ──────────────────────────────────────────────────────────────────────────────
# Post-execution footer
# Prints status (green/red) and elapsed duration to stderr.
# ──────────────────────────────────────────────────────────────────────────────
print_footer() {
    local exit_code="$1" elapsed_ms="$2" logfile="${3:-}"

    local B="" CY="" YL="" GN="" RD="" R=""
    if [[ -t 2 ]]; then
        B="\033[1m"
        CY="\033[1;36m"
        YL="\033[1;33m"
        GN="\033[1;32m"
        RD="\033[1;31m"
        R="\033[0m"
    fi

    local status_color status_label
    if [[ "$exit_code" -eq 0 ]]; then
        status_color="$GN"
        status_label="✓ exit 0"
    else
        status_color="$RD"
        status_label="✗ exit $exit_code"
    fi

    local duration
    duration="$(_fmt_duration "$elapsed_ms")"

    # Line widths (display columns) must total 68 each:
    #   "┌─ result " = 10 display cols  →  58 ─ chars to follow
    #   footer       = └ + 67 ─ chars  = 68 display cols
    local hdr_line="──────────────────────────────────────────────────────────$(_line_extension)"
    local sep_line="└───────────────────────────────────────────────────────────────────$(_line_extension)"
    printf >&2 "${CY}\r ┌─ result %s${R}\n" "$hdr_line"
    printf >&2 "${CY}\r │${R} ${B}Status   :${R} ${status_color}%s${R}\n" "$status_label"
    printf >&2 "${CY}\r │${R} ${B}Duration :${R} %s\n" "$duration"
    if [[ -n "$logfile" ]]; then
        printf >&2 "${CY}\r │${R} ${B}Log      :${R} ${YL}%s${R}\n" "$logfile"
    fi
    printf >&2 "${CY}\r %s${R}\n\n" "$sep_line"
}

# ──────────────────────────────────────────────────────────────────────────────
# Step executor
#
# Runs one command step (alias or literal) inside the container and prints the
# footer when done.  Reads from globals:
#   USE_ALIAS, EXEC_CMD, EXEC_ARGS[], EXEC_WORKDIR, ENV_FLAGS[], CONTAINER_NAME,
#   STEP_INTERACTIVE
# Optional parameter $1: path to logfile. If empty/omitted a new one is created.
# Sets global after return:
#   _STEP_SIG_RECEIVED — signal name (INT/TERM) if the step was interrupted, else ""
# Returns the step's exit code.  Does NOT re-raise signals or call exit.
# ──────────────────────────────────────────────────────────────────────────────
STEP_INTERACTIVE=0
_STEP_SIG_RECEIVED=""
_active_tmpfifo="" # cleaned up by EXIT trap if script dies mid-step

run_exec_step() {
    local _step_start_ms _logfile="${1:-}"
    _step_start_ms="$(_now_ms)"
    _STEP_SIG_RECEIVED=""

    if [[ "$STEP_INTERACTIVE" == "1" ]]; then
        # Interactive: foreground docker exec; trap INT to prevent bash's default
        # re-raise (which would kill the script before print_footer runs).
        local _sig=""
        trap '_sig=INT' INT

        local _exit=0
        if [[ "$USE_ALIAS" == "1" ]]; then
            docker exec -it -w "$EXEC_WORKDIR" "${ENV_FLAGS[@]}" "$CONTAINER_NAME" \
                sh -c "$EXEC_CMD" || _exit=$?
        else
            docker exec -it -w "$EXEC_WORKDIR" "${ENV_FLAGS[@]}" "$CONTAINER_NAME" \
                "${EXEC_ARGS[@]}" || _exit=$?
        fi
        trap - INT

        if [[ -n "$_sig" && "$_exit" -lt 128 ]]; then
            _exit=130 # 128 + SIGINT(2)
        fi
        [[ -n "$_sig" ]] && _STEP_SIG_RECEIVED="$_sig"

        print_footer "$_exit" "$(($(_now_ms) - _step_start_ms))"
        return "$_exit"

    else
        # Non-interactive: background docker exec feeding a FIFO; rolling display.
        local _tmpfifo _docker_pid _sig="" _exit=0
        _tmpfifo="$(mktemp -u)"
        mkfifo "$_tmpfifo"
        _active_tmpfifo="$_tmpfifo"

        # Use the provided logfile or create a fresh one for this step.
        # Logfiles are NOT removed so the user can inspect them after failure.
        if [[ -z "$_logfile" ]]; then
            _logfile="$(mktemp -t dex.XXXXXX.log)"
        fi

        # Write a plain-text step header to the logfile (no ANSI codes) so that
        # each step's output is clearly identified when viewing the log file.
        {
            printf '=%.0s' {1..80}
            printf '\n'
            printf 'Command   : %s\n' "$DISPLAY_CMD"
            printf 'Directory : %s\n' "$EXEC_WORKDIR"
            [[ -n "$ENV_DISPLAY" ]] && printf 'Env       : %s\n' "$ENV_DISPLAY"
            printf '=%.0s' {1..80}
            printf '\n'
        } >>"$_logfile"

        if [[ "$USE_ALIAS" == "1" ]]; then
            docker exec -w "$EXEC_WORKDIR" "${ENV_FLAGS[@]}" "$CONTAINER_NAME" \
                sh -c "$EXEC_CMD" >"$_tmpfifo"  2>&1 &
        else
            docker exec -w "$EXEC_WORKDIR" "${ENV_FLAGS[@]}" "$CONTAINER_NAME" \
                "${EXEC_ARGS[@]}" >"$_tmpfifo"  2>&1 &
        fi
        _docker_pid=$!

        # Signal handler: kill docker exec host-side AND container-side.
        # docker exec (no TTY) does NOT forward signals to the container process.
        _kill_step() {
            local sig="$1"
            _sig="$sig"
            kill -"$sig" "$_docker_pid" 2>/dev/null  || true
            local _exec_pid=$(docker exec "$CONTAINER_NAME" ps ax | grep "$EXEC_CMD" | grep -v "sh -c $EXEC_CMD" | sed -E 's,[[:space:]]+, ,g' | cut -f2 -d' ')
            if [[ -n "$_exec_pid" ]]; then
                docker exec "$CONTAINER_NAME" sh -c "kill -${sig} $_exec_pid 2>/dev/null" 2>/dev/null  || true
            else
                local _exec_pid=$(docker exec "$CONTAINER_NAME" ps ax | grep "$EXEC_CMD" | grep -v "sh -c $EXEC_CMD" | sed -E 's,[[:space:]]+, ,g' | cut -f2 -d' ')
                if [[ -n "$_exec_pid" ]]; then
                    die "Failed to find PID of docker exec process inside container to kill on signal ${sig}."
                fi
            fi
        }
        trap '_kill_step INT' INT
        trap '_kill_step TERM' TERM

        _rolling_display 10 "$_logfile" <"$_tmpfifo"  || true

        wait "$_docker_pid" || _exit=$?
        trap - INT TERM

        # docker exec (no TTY) sometimes exits 0 even when killed by a signal.
        if [[ -n "$_sig" && "$_exit" -lt 128 ]]; then
            case "$_sig" in
                INT) _exit=130 ;;
                TERM) _exit=143 ;;
            esac
        fi
        [[ -n "$_sig" ]] && _STEP_SIG_RECEIVED="$_sig"

        print_footer "$_exit" "$(($(_now_ms) - _step_start_ms))" "$_logfile"

        rm -f "$_tmpfifo" 2>/dev/null  || true
        _active_tmpfifo=""
        return "$_exit"
    fi
}

print_summary() {
    local profile="$1" image="$2" container="$3" workdir="$4" cmd="$5" env_display="$6" \
        ports_display="${7:-}"

    # ANSI colors — only when stderr is a terminal
    local B="" CY="" YL="" GR="" DIM="" R=""
    if [[ -t 2 ]]; then
        B="\033[1m"
        CY="\033[1;36m"
        YL="\033[1;33m"
        GR="\033[0;32m"
        DIM="\033[2m"
        R="\033[0m"
    fi

    local line="─────────────────────────────────────────────────────────────$(_line_extension)"
    # " ┌─ dex " = 8 display cols  →  61 ─ chars gives total width of 69
    # footer: " └" + 67 ─ chars = 69 display cols (same total)
    local footer="└───────────────────────────────────────────────────────────────────$(_line_extension)"
    printf >&2 "\n${CY} ┌─ dex %s${R}\n" "$line"
    printf >&2 "${CY} │${R} ${B}Profile   :${R} ${YL}%s${R}\n" "$profile"
    printf >&2 "${CY} │${R} ${B}Image     :${R} %s\n" "$image"
    printf >&2 "${CY} │${R} ${B}Container :${R} ${DIM}%s${R}\n" "$container"
    if [[ -n "$ports_display" ]]; then
        printf >&2 "${CY} │${R} ${B}Ports     :${R} ${GR}%s${R}\n" "$ports_display"
    fi
    printf >&2 "${CY} │${R} ${B}Directory :${R} ${GR}%s${R}\n" "$workdir"
    if [[ "$STEP_INTERACTIVE" == "1" ]]; then
        printf >&2 "${CY} │${R} ${B}Command   :${R} ${YL}%s${R} ${CY}(interactive)${R}\n" "$cmd"
    else
        printf >&2 "${CY} │${R} ${B}Command   :${R} ${YL}%s${R}\n" "$cmd"
    fi
    if [[ -n "$env_display" ]]; then
        printf >&2 "${CY} │${R} ${B}Env       :${R} ${GR}%s${R}\n" "$env_display"
    fi
    printf >&2 "${CY} %s${R}\n" "$footer"
}

# ──────────────────────────────────────────────────────────────────────────────
# Alias listing  (--list / -l)
# Reads from globals: PROFILE_NAME, FINAL_IMAGE, PROFILE_ENV, GLOBAL_CONFIG,
#   PROJECT_FILE, ALIAS_CMD, ALIAS_DESC, ALIAS_WORKDIR, ALIAS_ENV, ALIAS_PIPELINE,
#   ALIAS_INTERACTIVE, ALIAS_HIDDEN, CONTAINER_MOUNT
# Outputs to stdout; uses ANSI only when stdout is a terminal.
# ──────────────────────────────────────────────────────────────────────────────
list_aliases() {
    local B="" CY="" YL="" GR="" DIM="" MG="" R=""
    if [[ -t 1 ]]; then
        B=$'\033[1m'
        CY=$'\033[1;36m'
        YL=$'\033[1;33m'
        GR=$'\033[0;32m'
        DIM=$'\033[2m'
        MG=$'\033[1;35m'
        R=$'\033[0m'
    fi

    # Header box: " ┌─ dex aliases " (16 cols) + 53 dashes = 69 cols total
    local _hdr_dashes="─────────────────────────────────────────────────────$(_line_extension)"
    local _sep="└───────────────────────────────────────────────────────────────────$(_line_extension)"
    local _ftr="  └─────────────────────────────────────────────────────────────────$(_line_extension)"

    printf "${CY} ┌─ dex aliases %s${R}\n" "$_hdr_dashes"
    printf "${CY} │${R} ${B}Profile  :${R} ${YL}%s${R}\n" "$PROFILE_NAME"
    printf "${CY} │${R} ${B}Image    :${R} %s\n" "$FINAL_IMAGE"
    if [[ -f "$GLOBAL_CONFIG" ]]; then
        printf "${CY} │${R} ${B}Global   :${R} ${DIM}%s${R}\n" "$GLOBAL_CONFIG"
    fi
    if [[ -n "$REPO_CONFIG" ]]; then
        printf "${CY} │${R} ${B}Repo     :${R} ${CY}%s${R}\n" "$REPO_CONFIG"
    fi
    if [[ -n "$PROJECT_FILE" ]]; then
        printf "${CY} │${R} ${B}Local    :${R} ${DIM}%s${R}\n" "$PROJECT_FILE"
    fi
    if [[ -n "$PROFILE_ENV" ]]; then
        printf "${CY} │${R} ${B}Base env :${R} ${GR}%s${R}\n" "$PROFILE_ENV"
    fi
    printf "${CY} %s${R}\n" "$_sep"

    # Collect unique alias names from both maps, then sort alphabetically.
    # Hidden aliases (hidden = true) are excluded from the listing.
    local -A _seen=()
    local _n
    for _n in "${!ALIAS_CMD[@]}"; do
        [[ "${ALIAS_HIDDEN[$_n]-}" == "true" ]] && continue
        _seen["$_n"]=1
    done
    for _n in "${!ALIAS_PIPELINE[@]}"; do
        [[ -n "${ALIAS_PIPELINE[$_n]}" ]] && _seen["$_n"]=1
    done

    if [[ ${#_seen[@]} -eq 0 ]]; then
        printf "${CY}   │${R}  ${DIM}(no aliases defined for this profile)${R}\n"
    else
        local -a _names=()
        while IFS= read -r _n; do
            _names+=("$_n")
        done < <(printf '%s\n' "${!_seen[@]}" | sort)

        local _length=10
        for _n in "${_names[@]}"; do
            local _l=$(echo -n "$_n" | wc -m)
            if [[ $_l -gt $_length ]]; then
                _length=$_l
            fi
        done

        local _first=1
        for _n in "${_names[@]}"; do
            # Blank line between entries for readability.
            [[ "$_first" == "1" ]] && _first=0 || printf "${CY}   │${R}\n"

            if [[ -n "${ALIAS_PIPELINE[$_n]-}" ]]; then
                # Pipeline alias: show steps as a chain.
                local _steps_fmt
                _steps_fmt="$(printf '%s' "${ALIAS_PIPELINE[$_n]}" |
                    sed 's/[[:space:]]*,[[:space:]]*/  →  /g')"
                local _desc="${ALIAS_DESC[$_n]-}"

                if [[ -n "$_desc" ]]; then
                    local _meta="${YL}${_desc}${R}    "
                    printf "${CY}   │${R}  ${MG}%-${_length}s${R} %-8s %s\n" "$_n" "desc:" "$_meta"
                    _n=""
                    printf "${CY}   │${R}  ${MG}%-${_length}s${R} ${CY}[pipeline]${R}  %s\n" \
                        "" "$_steps_fmt"
                else
                    printf "${CY}   │${R}  ${MG}%-${_length}s${R} ${CY}[pipeline]${R}  %s\n" \
                        "$_n" "$_steps_fmt"
                fi
            else
                # Regular alias: name + command, then optional metadata line.
                local _cmd="${ALIAS_CMD[$_n]}"
                local _desc="${ALIAS_DESC[$_n]-}"
                local _workdir="${ALIAS_WORKDIR[$_n]:-$CONTAINER_MOUNT}"
                local _aenv="${ALIAS_ENV[$_n]-}"
                local _int="${ALIAS_INTERACTIVE[$_n]-}"

                # Second line: always show workdir; show alias-level env if set.
                if [[ -n "$_desc" ]]; then
                    local _meta="${YL}${_desc}${R}    "
                    printf "${CY}   │${R}  ${YL}%-${_length}s${R} %-8s %s\n" "$_n" "desc:" "$_meta"
                    _n=""
                fi

                local _tags=""
                [[ "$_int" == "true" ]] && _tags="  ${MG}(interactive)${R}"
                printf "${CY}   │${R}  ${YL}%-${_length}s${R} %-8s ${DIM}%s${R}%s\n" "$_n" "command:" "$_cmd" "$_tags"

                local _meta="${GR}${_workdir}${R}"
                printf "${CY}   │${R}  %-${_length}s %-8s %s\n" "" "workdir:" "$_meta"
                if [[ -n "$_aenv" ]]; then
                    local _meta="${YL}${_aenv}${R}"
                    printf "${CY}   │${R}  %-${_length}s %-8s %s\n" "" "env:" "$_meta"
                fi
            fi
        done
    fi

    printf "${CY} %s${R}\n" "$_ftr"
}

# ──────────────────────────────────────────────────────────────────────────────
# Help
# ──────────────────────────────────────────────────────────────────────────────
show_help() {
    local B="" CY="" YL="" GR="" DIM="" R=""
    if [[ -t 1 ]]; then
        B=$'\033[1m'
        CY=$'\033[1;36m'
        YL=$'\033[1;33m'
        GR=$'\033[0;32m'
        DIM=$'\033[2m'
        R=$'\033[0m'
    fi

    printf "${B}Usage:${R} ${YL}%s${R} [OPTIONS] [ALIAS | COMMAND [ARGS...]]\n" "$SCRIPT_NAME"
    printf "\n"
    printf "Transparently run commands inside a persistent Docker container.\n"
    printf "The git repository root is mounted at ${GR}%s${R}; the current working\n" "$CONTAINER_MOUNT"
    printf "directory is translated to the equivalent path in the container automatically.\n"

    printf "\n${CY}Options${R}\n"
    printf "  ${YL}-h${R}, ${YL}--help${R}               Show this help message and exit\n"
    printf "  ${YL}-l${R}, ${YL}--list${R}               List all aliases for the selected profile and exit\n"
    printf "  ${YL}-p${R}, ${YL}--profile${R} ${B}<profile>${R}  Select a named profile\n"
    printf "  ${YL}-e${R}, ${YL}--env${R} ${B}<spec>${R}         Extra environment variables (overrides config).\n"
    printf "                           ${DIM}Accepts comma-separated specs: KEY=val,OTHER=val${R}\n"
    printf "                           ${DIM}May be repeated: -e KEY=val -e OTHER=val${R}\n"
    printf "  ${YL}-I${R}, ${YL}--interactive${R}        Force all steps interactive (docker exec -it)\n"
    printf "  ${YL}-r${R}, ${YL}--restart${R}            Remove and recreate the container before running\n"
    printf "                           ${DIM}(applies updated port mappings and other creation-time settings)${R}\n"
    printf "  ${YL}-b${R}, ${YL}--rebuild${R}            Force rebuild of the Docker image\n"
    printf "                           ${DIM}(requires dockerfile in project config or profile)${R}\n"
    printf "                           ${DIM}Can be used without a command to rebuild only${R}\n"
    printf "  ${YL}-s${R}, ${YL}--stop${R}               Stop and remove the current project's container\n"
    printf "  ${YL}-S${R}, ${YL}--stop-all${R}           Stop and remove ALL dex-managed containers\n"

    printf "\n${CY}Configuration${R}\n"
    printf "  Config files are loaded in priority order (highest wins):\n"
    printf "\n"
    printf "  ${B}1. Local project config${R}  ${DIM}(personal, not committed)${R}\n"
    printf "     ${GR}~/.dex.d/<name>.conf${R}\n"
    printf "     ${GR}~/.local/share/.dex.d/<name>.conf${R}  ${DIM}(fallback)${R}\n"
    printf "     ${DIM}Matched by regex 'pattern' against the git root path.${R}\n"
    printf "\n"
    printf "  ${B}2. Repository config${R}  ${DIM}(committed, shared with the team)${R}\n"
    printf "     ${GR}<git-root>/.dex.conf${R}\n"
    printf "\n"
    printf "  ${B}3. Global config${R}  ${DIM}(optional personal defaults)${R}\n"
    printf "     ${GR}~/.dex.conf${R}\n"
    printf "     ${GR}~/.local/share/.dex.conf${R}  ${DIM}(fallback)${R}\n"

    printf "\n${CY}Aliases${R}\n"
    printf "  If the first argument matches a defined alias, its predefined command, working\n"
    printf "  directory, and environment variables are used.  If the alias has a ${B}pipeline${R}\n"
    printf "  key, each listed step alias is run in order — stopping on the first failure.\n"
    printf "  Otherwise the full command line is executed literally inside the container.\n"

    printf "\n${CY}Interactive mode${R}\n"
    printf "  Set ${YL}interactive = true${R} in an alias section to make that alias always run\n"
    printf "  with a TTY (docker exec -it), even inside a pipeline.  The global ${YL}-I${R} flag\n"
    printf "  forces all steps interactive regardless of this setting.\n"
    printf "\n"
    printf "  ${DIM}[alias:shell]${R}\n"
    printf "  ${DIM}cmd         = bash${R}\n"
    printf "  ${DIM}interactive = true${R}\n"

    printf "\n${CY}Port mapping${R}\n"
    printf "  Set ${YL}ports${R} in a profile section to publish ports when the container is created.\n"
    printf "  Accepts the same format as ${B}docker run -p${R} (comma-separated).\n"
    printf "  Port bindings are fixed at container creation time; use ${YL}-r${R} to recreate.\n"
    printf "\n"
    printf "  ${DIM}[myprofile]${R}\n"
    printf "  ${DIM}ports = 8080:8080,5432:5432${R}\n"

    printf "\n${CY}Pipeline example${R}\n"
    printf "  ${DIM}[alias:ci]${R}\n"
    printf "  ${DIM}pipeline = configure,build,test${R}\n"
    printf "\n"
    printf "  ${DIM}[alias:configure]${R}  ${DIM}cmd = cmake -S . -B build${R}\n"
    printf "  ${DIM}[alias:build]${R}      ${DIM}cmd = cmake --build build${R}\n"
    printf "  ${DIM}[alias:test]${R}       ${DIM}cmd = ctest --test-dir build${R}\n"

    printf "\n${CY}Examples${R}\n"
    printf "  ${YL}%s -l${R}                   ${DIM}# List all aliases for the active profile${R}\n" "$SCRIPT_NAME"
    printf "  ${YL}%s -l -p clang${R}          ${DIM}# List aliases for the 'clang' profile${R}\n" "$SCRIPT_NAME"
    printf "  ${YL}%s cmake -S . -B build${R}  ${DIM}# Run cmake (CWD mapped to %s/...)${R}\n" "$SCRIPT_NAME" "$CONTAINER_MOUNT"
    printf "  ${YL}%s build${R}                ${DIM}# Run the 'build' alias${R}\n" "$SCRIPT_NAME"
    printf "  ${YL}%s ci${R}                   ${DIM}# Run the 'ci' pipeline (configure → build → test)${R}\n" "$SCRIPT_NAME"
    printf "  ${YL}%s -I bash${R}              ${DIM}# Open an interactive shell in the container${R}\n" "$SCRIPT_NAME"
    printf "  ${YL}%s -p clang build${R}       ${DIM}# Use the 'clang' profile, then run 'build'${R}\n" "$SCRIPT_NAME"
    printf "  ${YL}%s -e JOBS=8 build${R}      ${DIM}# Pass an extra env var to the 'build' alias${R}\n" "$SCRIPT_NAME"
    printf "  ${YL}%s -e A=1 -e B=2 build${R}  ${DIM}# Multiple env vars${R}\n" "$SCRIPT_NAME"
    printf "  ${YL}%s -b -r build${R}          ${DIM}# Rebuild image AND recreate container, then build${R}\n" "$SCRIPT_NAME"
    printf "  ${YL}%s -b${R}                   ${DIM}# Rebuild image only (no command)${R}\n" "$SCRIPT_NAME"
    printf "  ${YL}%s -r build${R}             ${DIM}# Recreate container (e.g. after changing ports)${R}\n" "$SCRIPT_NAME"
    printf "  ${YL}%s -s${R}                   ${DIM}# Stop the current project's container${R}\n" "$SCRIPT_NAME"
    printf "  ${YL}%s -S${R}                   ${DIM}# Stop all dex-managed containers${R}\n" "$SCRIPT_NAME"

    printf "\n${DIM}Config file format: see dex.conf.example and dex.d/example.conf${R}\n\n"
}

# ──────────────────────────────────────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────────────────────────────────────

# Clean up log files from previous runs that are older than 3 minutes.
# Log files are created with mktemp -t dex.XXXXXX.log in /tmp (or $TMPDIR).
find "${TMPDIR:-/tmp}" -maxdepth 1 -name 'dex.*.log' -mmin +3 \
    -delete 2>/dev/null  || true

FORCE_REBUILD=0
FORCE_RESTART=0
FORCE_STOP=0
STOP_ALL=0
LIST_ALIASES=0
PROFILE_OVERRIDE=""
INTERACTIVE=0
CLI_ENV="" # extra env vars from -e / --env flags (comma-separated, highest priority)

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h | --help)
            show_help
            exit 0
            ;;
        -b | --rebuild)
            FORCE_REBUILD=1
            shift
            ;;
        -r | --restart)
            FORCE_RESTART=1
            shift
            ;;
        -s | --stop)
            FORCE_STOP=1
            shift
            ;;
        -S | --stop-all)
            STOP_ALL=1
            shift
            ;;
        -l | --list)
            LIST_ALIASES=1
            shift
            ;;
        -I | --interactive)
            INTERACTIVE=1
            shift
            ;;
        -p | --profile)
            [[ $# -lt 2 ]] && die "'${_CYL}$1${_CR}' requires a profile name argument."
            PROFILE_OVERRIDE="$2"
            shift 2
            ;;
        --profile=*)
            PROFILE_OVERRIDE="${1#--profile=}"
            shift
            ;;
        -e | --env)
            [[ $# -lt 2 ]] && die "'${_CYL}$1${_CR}' requires an argument."
            CLI_ENV="${CLI_ENV}${CLI_ENV:+,}$2"
            shift 2
            ;;
        --env=*)
            _v="${1#--env=}"
            CLI_ENV="${CLI_ENV}${CLI_ENV:+,}${_v}"
            unset _v
            shift
            ;;
        --)
            shift
            break
            ;;
        -*) die "Unknown option: ${_CYL}$1${_CR}.  Run '${SCRIPT_NAME} --help' for usage." ;;
        *) break ;;
    esac
done

if [[ $# -eq 0 && "$LIST_ALIASES" != "1" && "$FORCE_STOP" != "1" && "$FORCE_REBUILD" != "1" && "$STOP_ALL" != "1" ]]; then
    show_help
    exit 0
fi

# ── Stop all dex-managed containers (--stop-all / -S) ────────────────────────
# Handled before git root detection: no repo context needed.
if [[ "$STOP_ALL" == "1" ]]; then
    _dex_containers=()
    while IFS= read -r _cname; do
        [[ "$_cname" == dex-* ]] && _dex_containers+=("$_cname")
    done < <(docker ps -a --filter "name=dex-" --format "{{.Names}}" 2>/dev/null || true)
    if [[ ${#_dex_containers[@]} -eq 0 ]]; then
        info "No dex-managed containers found."
    else
        for _cname in "${_dex_containers[@]}"; do
            info "Removing container '${_CDIM}${_cname}${_CR}' ..."
            docker rm -f "$_cname" >/dev/null
        done
    fi
    unset _dex_containers _cname
    exit 0
fi

# ── Git root detection (supports normal repos and worktrees) ──────────────────
GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"  ||
    die "Not inside a git repository."

# ── Config loading: global (optional) → repo → local project ─────────────────
# Global config is optional; a repo or project config alone is sufficient.
if [[ -f "$GLOBAL_CONFIG" ]]; then
    ini_parse "$GLOBAL_CONFIG"
fi

# In-repository config: <git-root>/.dex.conf  (committed, shared)
find_repo_config "$GIT_ROOT"

# Local user project config: ~/.dex.d/*.conf  (personal, not committed)
find_project_config "$GIT_ROOT"

# ── Profile name resolution ───────────────────────────────────────────────────
# Default is "default"; repo config can suggest a different default; local
# project config can override that; -p / --profile overrides everything.
PROFILE_NAME="default"
if [[ -n "$REPO_CONFIG" ]]; then
    _p="$(ini_get "$REPO_CONFIG" "project" "profile")"
    [[ -n "$_p" ]] && PROFILE_NAME="$_p"
    unset _p
fi
if [[ -n "$PROJECT_FILE" ]]; then
    _p="$(ini_get "$PROJECT_FILE" "project" "profile")"
    [[ -n "$_p" ]] && PROFILE_NAME="$_p"
    unset _p
fi
[[ -n "$PROFILE_OVERRIDE" ]] && PROFILE_NAME="$PROFILE_OVERRIDE"

# ── Load profile, then overlay project settings ───────────────────────────────
load_profile "$PROFILE_NAME"
apply_project_config "$PROFILE_NAME"

# ── Resolve final Docker image ────────────────────────────────────────────────
# Compute a slug for the profile name (safe for use in container/image names)
_profile_slug="$(printf '%s' "$PROFILE_NAME" |
    tr '[:upper:]' '[:lower:]' |
    tr -cs 'a-z0-9' '-' |
    sed 's/^-\+//;s/-\+$//')"

FINAL_IMAGE=""
# Prefer PROJECT_DOCKERFILE (from [project] section) over PROFILE_DOCKERFILE.
EFFECTIVE_DOCKERFILE="${PROJECT_DOCKERFILE:-$PROFILE_DOCKERFILE}"
if [[ -n "$EFFECTIVE_DOCKERFILE" ]]; then
    # Dockerfile-built image: tag derived from the Dockerfile path so that all
    # projects sharing the same Dockerfile reuse the same image.
    _slug="$(printf '%s' "$EFFECTIVE_DOCKERFILE" |
        tr '[:upper:]' '[:lower:]' |
        tr -cs 'a-z0-9' '-' |
        sed 's/^-\+//;s/-\+$//')"
    FINAL_IMAGE="dex-${_slug}:local"
    unset _slug
fi
[[ -z "$FINAL_IMAGE" && -n "$PROJECT_IMAGE" ]] && FINAL_IMAGE="$PROJECT_IMAGE"
[[ -z "$FINAL_IMAGE" && -n "$PROFILE_IMAGE" ]] && FINAL_IMAGE="$PROFILE_IMAGE"
[[ -z "$FINAL_IMAGE" ]] &&
    die "No Docker image configured. Set 'image' in profile '${_CCY}${PROFILE_NAME}${_CR}' or the project config."

# Container name includes the profile so each profile gets its own container.
CONTAINER_NAME="$(container_name_from_path "$GIT_ROOT")-${_profile_slug}"
unset _profile_slug

# ── CWD → container path ──────────────────────────────────────────────────────
REL_PATH="${PWD#"$GIT_ROOT"}"
CONTAINER_WORKDIR="${CONTAINER_MOUNT}${REL_PATH}"

# ── EXIT trap: clean up any in-progress FIFO ─────────────────────────────────
trap 'rm -f "$_active_tmpfifo"' EXIT

# ── Resolve first argument: alias, pipeline alias, or literal command ─────────
USE_ALIAS=0
ALIAS_NAME=""
if [[ $# -gt 0 && -n "${ALIAS_CMD["$1"]+x}" && "${ALIAS_HIDDEN["$1"]-}" != "true" ]]; then
    USE_ALIAS=1
    ALIAS_NAME="$1"
elif [[ $# -gt 0 && -n "${ALIAS_PIPELINE["$1"]-}" ]]; then
    USE_ALIAS=1
    ALIAS_NAME="$1"
fi

# ── List aliases and exit (--list / -l) ──────────────────────────────────────
if [[ "$LIST_ALIASES" == "1" ]]; then
    list_aliases
    exit 0
fi

# ── Ensure image and container are ready ──────────────────────────────────────
ensure_image "$FINAL_IMAGE" "$EFFECTIVE_DOCKERFILE" "$FORCE_REBUILD"

# If no alias or command was given (e.g. bare `dex -b`), the image step is all
# that was needed — skip container creation/start entirely.
[[ "$USE_ALIAS" == "0" && $# -eq 0 ]] && exit 0

ensure_container "$CONTAINER_NAME" "$FINAL_IMAGE" "$GIT_ROOT" "$PROFILE_PORTS" "$FORCE_RESTART" "$FORCE_STOP"

# ── Helper: set globals for one step alias and print its summary ──────────────
_setup_step() {
    local step_alias="$1" pipeline_label="${2:-}"
    EXEC_WORKDIR="${ALIAS_WORKDIR[$step_alias]:-$CONTAINER_WORKDIR}"
    # Evaluate command substitutions in the workdir value, e.g.
    #   workdir = /workspace/$(git branch --show-current)
    if [[ "$EXEC_WORKDIR" == *'$('* || "$EXEC_WORKDIR" == *'`'* ]]; then
        eval "EXEC_WORKDIR=${EXEC_WORKDIR}"
    fi
    EXEC_CMD="${ALIAS_CMD[$step_alias]}"
    # A step is interactive if the alias declares it OR the global -I flag is set.
    if [[ "${ALIAS_INTERACTIVE[$step_alias]-}" == "true" || "$INTERACTIVE" == "1" ]]; then
        STEP_INTERACTIVE=1
    else
        STEP_INTERACTIVE=0
    fi
    if [[ -n "$pipeline_label" ]]; then
        DISPLAY_CMD="[${pipeline_label}:${step_alias}] → ${EXEC_CMD}"
    else
        DISPLAY_CMD="[${step_alias}] → ${EXEC_CMD}"
    fi
    local _aenv="${ALIAS_ENV[$step_alias]-}"
    COMBINED_ENV="$PROFILE_ENV"
    [[ -n "$_aenv" ]] && COMBINED_ENV="${COMBINED_ENV}${COMBINED_ENV:+,}${_aenv}"
    [[ -n "$CLI_ENV" ]] && COMBINED_ENV="${COMBINED_ENV}${COMBINED_ENV:+,}${CLI_ENV}"
    _apply_combined_env
    print_summary "$PROFILE_NAME" "$FINAL_IMAGE" "$CONTAINER_NAME" \
        "$EXEC_WORKDIR" "$DISPLAY_CMD" "$ENV_DISPLAY" "$PROFILE_PORTS"
}

# ── Dispatch ──────────────────────────────────────────────────────────────────
_overall_exit=0

# Create a single logfile for the entire invocation (shared across pipeline steps).
# Interactive steps skip writing to it, but non-interactive steps in the same
# pipeline still use it for capture.
_run_logfile="$(mktemp -t dex.XXXXXX.log)"

if [[ "$USE_ALIAS" == "1" && -n "${ALIAS_PIPELINE[$ALIAS_NAME]-}" ]]; then
    # Pipeline alias: run each referenced step alias in order, fail-fast.
    IFS=',' read -r -a _pipeline_steps <<<"${ALIAS_PIPELINE[$ALIAS_NAME]}"
    for _step in "${_pipeline_steps[@]}"; do
        _step="${_step// /}" # trim any whitespace around the comma
        [[ -n "${ALIAS_CMD[$_step]+x}" ]] ||
            die "Pipeline '${_CCY}${ALIAS_NAME}${_CR}': step '${_CYL}${_step}${_CR}' is not a defined alias"
        USE_ALIAS=1
        _setup_step "$_step" "$ALIAS_NAME"
        run_exec_step "$_run_logfile" || _overall_exit=$?
        if [[ "$_overall_exit" -ne 0 ]]; then
            break
        fi
    done

elif [[ "$USE_ALIAS" == "1" ]]; then
    # Single alias step.
    _setup_step "$ALIAS_NAME"
    run_exec_step "$_run_logfile" || _overall_exit=$?

else
    # Literal command: pass args directly.
    EXEC_ARGS=("$@")
    EXEC_WORKDIR="$CONTAINER_WORKDIR"
    EXEC_CMD=""
    DISPLAY_CMD="$(printf '%s ' "$@")"
    STEP_INTERACTIVE="$INTERACTIVE"
    COMBINED_ENV="$PROFILE_ENV"
    [[ -n "$CLI_ENV" ]] && COMBINED_ENV="${COMBINED_ENV}${COMBINED_ENV:+,}${CLI_ENV}"
    _apply_combined_env
    print_summary "$PROFILE_NAME" "$FINAL_IMAGE" "$CONTAINER_NAME" \
        "$EXEC_WORKDIR" "$DISPLAY_CMD" "$ENV_DISPLAY" "$PROFILE_PORTS"
    run_exec_step "$_run_logfile" || _overall_exit=$?
fi

# Re-raise signal so the parent shell sees the correct exit status.
if [[ "$_overall_exit" -gt 128 ]]; then
    _rsig=$((_overall_exit - 128))
    trap - INT TERM EXIT
    rm -f "$_active_tmpfifo" 2>/dev/null  || true
    kill -"$_rsig" $$
fi

exit "$_overall_exit"
